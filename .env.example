# Copy to .env. Everything works with NONE of this set (LOCAL mode).
SARATHI_MODE=local          # local | live

# LIVE mode only ---------------------------------------------------
GROQ_API_KEY=
GEMINI_API_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_KEY=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# admin bootstrap key, used to mint the first API key via the admin API
SARATHI_ADMIN_TOKEN=change-me
